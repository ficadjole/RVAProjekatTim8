<Window x:Class="Statistics.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Statistics.ViewModels"
        Title="Artwork Statistics" 
        Height="750" 
        Width="920"
        WindowStartupLocation="CenterScreen"
        mc:Ignorable="d">

    <Window.DataContext>
        <vm:StatisticsViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Height" Value="36"/>
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="btnBorder" Background="{TemplateBinding Background}" CornerRadius="4" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="15,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="btnBorder" Property="Opacity" Value="0.5"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="btnBorder" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#4A5568"/>
        </Style>
    </Window.Resources>

    <Grid Background="#F8FAFC" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="📊" FontSize="22" Margin="5,0,10,0" VerticalAlignment="Center"/>
            <TextBlock Text="Statistička Obrada Podataka" 
                       FontSize="20" 
                       FontWeight="Bold" 
                       Foreground="#1A202C" 
                       VerticalAlignment="Center"/>
        </StackPanel>

        <GroupBox Grid.Row="1" Header=" Preuzimanje podataka ">
            <Border Background="White" CornerRadius="6" Padding="15">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Umetničko delo:" Width="130" VerticalAlignment="Center" FontWeight="Normal" Foreground="#4A5568"/>

                        <StackPanel Orientation="Horizontal">
                            <ComboBox ItemsSource="{Binding Artworks}"
                                      SelectedItem="{Binding SelectedArtwork}"
                                      DisplayMemberPath="Title"
                                      Width="250"/>

                            <Button Content="🔄 Osveži" 
                                    Command="{Binding RefreshArtworksCommand}"
                                    Style="{StaticResource ModernButtonStyle}"
                                    Background="#4A5568" 
                                    Height="30"
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="Mesec:" Width="130" VerticalAlignment="Center" FontWeight="Normal" Foreground="#4A5568"/>
                        <ComboBox ItemsSource="{Binding Months}"
                                  SelectedItem="{Binding SelectedMonth}"
                                  Width="80" Margin="0,0,20,0"/>

                        <TextBlock Text="Godina:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Normal" Foreground="#4A5568"/>
                        <ComboBox ItemsSource="{Binding Years}"
                                  SelectedItem="{Binding SelectedYear}"
                                  Width="90"/>
                    </StackPanel>

                    <Button Content="Preuzmi podatke" 
                            Command="{Binding FetchDataCommand}"
                            Style="{StaticResource ModernButtonStyle}"
                            Background="#2B6CB0" 
                            HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>
        </GroupBox>

        <GroupBox Grid.Row="2" Header=" Lista merenja i status ">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#EDF2F7" Padding="10,6" CornerRadius="4,4,0,0">
                    <TextBlock Text="{Binding MonitoringDisplay.Count, StringFormat='Učitano ključeva/merenja iz rečnika: {0}'}" 
                               FontStyle="Italic" 
                               Foreground="#4A5568"
                               FontWeight="Normal"/>
                </Border>

                <ListBox Grid.Row="1" 
                         ItemsSource="{Binding MonitoringDisplay}"
                         FontFamily="Consolas" 
                         FontSize="12"
                         BorderBrush="#E2E8F0"
                         BorderThickness="1,0,1,1"
                         Background="White"/>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="3" Header=" Statistička metoda ">
            <Border Background="White" CornerRadius="6" Padding="15">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Izbor metode:" Width="130" VerticalAlignment="Center" FontWeight="Normal" Foreground="#4A5568"/>
                    <ComboBox ItemsSource="{Binding StatisticsMethods}"
                              SelectedItem="{Binding SelectedStrategy}"
                              Width="380"/>
                </StackPanel>
            </Border>
        </GroupBox>

        <Grid Grid.Row="4" Margin="0,5,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" 
                    Background="White"
                    BorderBrush="#E2E8F0" 
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="15" 
                    Margin="0,0,15,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" Direction="270" ShadowDepth="1" Opacity="0.04"/>
                </Border.Effect>
                <TextBlock Text="{Binding StatisticsResult}" 
                           FontSize="15" 
                           FontWeight="SemiBold" 
                           Foreground="#2D3748"
                           TextWrapping="Wrap"/>
            </Border>

            <Button Grid.Column="1" 
                    Content="Exportuj u CSV"
                    Style="{StaticResource ModernButtonStyle}"
                    Background="#319795"
                    VerticalAlignment="Stretch"
                    Command="{Binding ExportCsvCommand}"/>
        </Grid>
    </Grid>
</Window>