<Window
    x:Class="RVAProjekatTim8.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:RVAProjekatTim8"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="clr-namespace:RVAProjekatTim8.Views"
    Title="Informacioni sistem - Umetnički muzej"
    Width="950"
    Height="650"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Window.Resources>
        <Style x:Key="GlobalToolbarButtonStyle" TargetType="Button">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#CBD5E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#4A5568"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="btnBorder" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" 
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="btnBorder" Value="#EDF2F7" Property="Background"/>
                                <Setter TargetName="btnBorder" Value="#A0AEC0" Property="BorderBrush"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="btnBorder" Value="#E2E8F0" Property="Background"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="btnBorder" Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#4A5568"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
        </Style>
    </Window.Resources>

    <Grid Background="#F1F5F9" Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center" Orientation="Horizontal">
                <TextBlock Text="🏛️" FontSize="18" Margin="5,0,8,0" VerticalAlignment="Center"/>
                <TextBlock Text="Upravljanje Umeticnkim delima i Monitoringom" 
                           FontSize="15" 
                           FontWeight="Bold" 
                           Foreground="#1A202C" 
                           VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Style="{StaticResource GlobalToolbarButtonStyle}"
                        Command="{Binding UndoCommand}"
                        Content="↶" 
                        ToolTip="Poništi izmenu (Undo)"/>

                <Button Style="{StaticResource GlobalToolbarButtonStyle}"
                        Command="{Binding RedoCommand}"
                        Content="↷" 
                        ToolTip="Ponovi poništenu izmenu (Redo)"/>
            </StackPanel>
        </Grid>

        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
            <TabItem Header="Umetnička dela">
                <Grid Background="Transparent" Margin="0,10,0,0">
                    <views:ArtworkListView DataContext="{Binding ArtworkListViewModel}" />
                </Grid>
            </TabItem>
            <TabItem Header="Praćenje stanja">
                <Grid Background="Transparent" Margin="0,10,0,0">
                    <views:ArtworkMonitoringListView DataContext="{Binding ArtworkMonitoringListViewModel}" />
                </Grid>
            </TabItem>
        </TabControl>

    </Grid>
</Window>