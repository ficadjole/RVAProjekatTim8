<UserControl
    x:Class="RVAProjekatTim8.Views.ArtworkListView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:RVAProjekatTim8.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel
            Grid.Row="0"
            Margin="0,0,0,8"
            Orientation="Horizontal">
            <TextBlock
                Margin="0,0,8,0"
                VerticalAlignment="Center"
                Text="Pretraga:" />
            <TextBox Width="250" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>

        <DataGrid
            Grid.Row="1"
            AutoGenerateColumns="False"
            IsReadOnly="True"
            ItemsSource="{Binding FilteredArtworks}"
            SelectedItem="{Binding SelectedArtwork}">
            <DataGrid.Columns>
                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding Title}"
                    Header="Naziv" />
                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding Artist}"
                    Header="Autor" />
                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding Medium}"
                    Header="Tehnika" />
                <DataGridTextColumn
                    Width="Auto"
                    Binding="{Binding YearCreated}"
                    Header="Godina" />
                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding Style}"
                    Header="Stil" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel
            Grid.Row="2"
            Margin="0,8,0,0"
            Orientation="Horizontal">
            <Button
                Width="80"
                Margin="0,0,8,0"
                Command="{Binding AddArtworkCommand}"
                Content="Dodaj" />
            <Button
                Width="80"
                Margin="0,0,8,0"
                Command="{Binding EditArtworkCommand}"
                Content="Izmeni" />
            <Button
                Width="80"
                Command="{Binding DeleteArtworkCommand}"
                Content="Obriši" />
        </StackPanel>
    </Grid>
</UserControl>
