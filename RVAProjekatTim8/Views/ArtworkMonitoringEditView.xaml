<UserControl
    x:Class="RVAProjekatTim8.Views.ArtworkMonitoringEditView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:RVAProjekatTim8.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <StackPanel Width="320" Margin="12">
        <TextBlock Text="Umetničko delo:" />
        <ComboBox
            DisplayMemberPath="Title"
            ItemsSource="{Binding AvailableArtworks}"
            SelectedValue="{Binding ArtworkId, ValidatesOnDataErrors=True}"
            SelectedValuePath="Id" />

        <TextBlock Margin="0,8,0,0" Text="Vreme merenja:" />
        <DatePicker SelectedDate="{Binding MonitoringTime, ValidatesOnDataErrors=True}" />

        <TextBlock Margin="0,8,0,0" Text="Izloženost svetlosti (lux):" />
        <TextBox Text="{Binding LightExposure, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Margin="0,8,0,0" Text="Zagađenost vazduha (μg/m³):" />
        <TextBox Text="{Binding AirPollution, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Margin="0,8,0,0" Text="Stanje:" />
        <ComboBox ItemsSource="{Binding AvailableStates}" SelectedItem="{Binding State}" />

        <StackPanel Margin="0,16,0,0" Orientation="Horizontal">
            <Button
                Width="80"
                Margin="0,0,8,0"
                Command="{Binding SaveCommand}"
                Content="Sačuvaj" />
            <Button
                Width="80"
                Command="{Binding CancelCommand}"
                Content="Otkaži" />
        </StackPanel>
    </StackPanel>
</UserControl>
