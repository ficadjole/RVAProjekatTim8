<UserControl
    x:Class="RVAProjekatTim8.Views.ArtworkEditView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:RVAProjekatTim8.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">
    <UserControl.Resources>
        <!--  Stil koji crveno oboji ivicu kontrole kada Validation.HasError postane true  -->
        <Style TargetType="TextBox">
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="True">
                    <Setter Property="BorderBrush" Value="Red" />
                    <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors).CurrentItem.ErrorContent}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <StackPanel Margin="12">
        <TextBlock Text="Naziv dela:" />
        <TextBox Text="{Binding Title, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Margin="0,8,0,0" Text="Autor:" />
        <TextBox Text="{Binding Artist, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Margin="0,8,0,0" Text="Tehnika izrade:" />
        <TextBox Text="{Binding Medium, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Margin="0,8,0,0" Text="Godina nastanka:" />
        <TextBox Text="{Binding YearCreated, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Margin="0,8,0,0" Text="Umetnički stil:" />
        <TextBox Text="{Binding Style, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged}" />

        <Button
            Margin="0,16,0,0"
            Command="{Binding SaveCommand}"
            Content="Sačuvaj"
            IsEnabled="{Binding IsValid}" />
        <Button
            Margin="0,16,0,0"
            Command="{Binding CancelCommand}"
            Content="Otkaži" />
    </StackPanel>
</UserControl>
