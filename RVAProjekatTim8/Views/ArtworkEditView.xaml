<UserControl
    x:Class="RVAProjekatTim8.Views.ArtworkEditView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:RVAProjekatTim8.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="550"
    d:DesignWidth="450"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Margin" Value="0,4,0,12" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="BorderBrush" Value="#CCCCCC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="4" />
                </Style>
            </Style.Resources>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#2A73D2" />
                </Trigger>
                <Trigger Property="Validation.HasError" Value="True">
                    <Setter Property="BorderBrush" Value="#D32F2F" />
                    <Setter Property="BorderThickness" Value="1.5" />
                    <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors).CurrentItem.ErrorContent}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#333333" />
        </Style>

        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="4" />
                </Style>
            </Style.Resources>
        </Style>
    </UserControl.Resources>

    <Grid Background="#F5F7FA">
        <Border Background="White" 
                CornerRadius="8" 
                Margin="20" 
                Padding="25"
                MaxWidth="400"
                VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Direction="270" ShadowDepth="2" Opacity="0.1"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="Podaci o Umetničkom Delu" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Foreground="#1A202C" 
                           Margin="0,0,0,20" 
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Naziv dela:" />
                <TextBox Text="{Binding Title, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Text="Autor:" />
                <TextBox Text="{Binding Artist, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Text="Tehnika izrade:" />
                <TextBox Text="{Binding Medium, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Text="Godina nastanka:" />
                <TextBox Text="{Binding YearCreated, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Text="Umetnički stil:" />
                <TextBox Text="{Binding Style, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged}" />

                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Style="{StaticResource ModernButtonStyle}"
                            Background="#E2E8F0"
                            Foreground="#4A5568"
                            BorderThickness="0"
                            Margin="0,0,6,0"
                            Command="{Binding CancelCommand}"
                            Content="Otkaži" />

                    <Button Grid.Column="1"
                            Style="{StaticResource ModernButtonStyle}"
                            Background="#2A73D2"
                            Foreground="White"
                            BorderThickness="0"
                            Margin="6,0,0,0"
                            Command="{Binding SaveCommand}"
                            Content="Sačuvaj"
                            IsEnabled="{Binding IsValid}" />
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>